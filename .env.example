# Root-level env template. The backend reads its own env file:
#   see backend/.env.example — copy it to backend/.env and fill in values.
#
# This root file is kept for docker-compose variable substitution (future use).
DATABASE_URL=sqlite:///./placeiq.db
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
CORS_ORIGINS=http://localhost:3000
