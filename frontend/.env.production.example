# Production environment for the PlaceIQ frontend (e.g. on Vercel).
#
# NEXT_PUBLIC_API_URL must point at the PUBLIC URL of the hosted FastAPI
# backend (Railway / Render / Fly / etc.) — NOT localhost, since this value is
# baked into the browser bundle at build time.
#
# Example:
#   NEXT_PUBLIC_API_URL=https://placeiq-api.up.railway.app
#
# Remember to also add your Vercel domain (e.g. https://placeiq.vercel.app)
# to CORS_ORIGINS in the backend's environment, or API calls will be blocked.
NEXT_PUBLIC_API_URL=https://your-hosted-backend.example.com
