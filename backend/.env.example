# Copy to .env and fill in. .env is gitignored — never commit real keys.
DATABASE_URL=sqlite:///./placeiq.db
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
CORS_ORIGINS=http://localhost:3000
# HS256 signing secret for auth JWTs (7-day expiry). Change in production.
JWT_SECRET=dev-jwt-secret-change-me-in-prod
# Header value required for /api/admin/* endpoints (X-Admin-Key).
ADMIN_KEY=dev-admin-key
